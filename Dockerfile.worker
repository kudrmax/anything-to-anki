FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg espeak-ng && rm -rf /var/lib/apt/lists/*
WORKDIR /app

COPY backend/pyproject.toml ./backend/
RUN mkdir -p ./backend/src/backend && touch ./backend/src/backend/__init__.py
RUN pip install --no-cache-dir "./backend[tts]"

COPY backend/src/ ./backend/src/
RUN pip install --no-deps --no-cache-dir ./backend

COPY config /app/config

ENV DATA_DIR=/data

CMD ["python", "-m", "backend.infrastructure.queue"]
