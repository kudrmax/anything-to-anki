# Имя docker compose проекта. Должно отличаться между копиями, чтобы
# контейнеры не коллились. docker compose читает эту переменную автоматически.
COMPOSE_PROJECT_NAME=anything-anki-dev

# Визуальный лейбл — отображается в UI как бейдж. Код не принимает решений
# на основе этого значения.
INSTANCE_ENV_NAME=dev

# Порты для main-копии (dev или prod).
PORT=17832
AI_PROXY_PORT=8766

# Порты для worktree. Все worktree делят одну пару портов —
# одновременно работает только один.
WORKTREE_PORT=17833
WORKTREE_AI_PROXY_PORT=8767

# Путь к папке с unified-словарями (JSON файлы).
# По умолчанию: dictionaries/ в корне проекта.
# DICTIONARIES_DIR=./dictionaries
