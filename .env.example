# Визуальный лейбл — отображается в UI как бейдж. Код не принимает решений
# на основе этого значения.
INSTANCE_ENV_NAME=dev

# Порты для main-копии (dev или prod).
PORT=17832
AI_PROXY_PORT=8766

# Порты для worktree. Все worktree делят одну пару портов —
# одновременно работает только один.
WORKTREE_PORT=17833
WORKTREE_AI_PROXY_PORT=8767

# Путь к папке с unified-словарями (JSON файлы). Обязательно.
# Конвертеры: https://github.com/kudrmax/anything-to-anki-parsers
DICTIONARIES_DIR=/path/to/your/unified/dictionaries
